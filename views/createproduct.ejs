<%- include('./partials/header') %>

    <% if(success.length>0){ %>
        <div
            class="fixed top-24 left-1/2 -translate-x-1/2 z-[100] px-5 py-3 rounded-lg bg-blue-600 text-white shadow-lg">
            <span class="inline-block mt-1 mb-1 text-white">
                <%= success %>
            </span>
        </div>
        <% } %>

            <div class="min-h-screen flex flex-col">
                <div class="container px-10 py-20 flex flex-grow">
                    <div class="w-[25%] flex h-screen flex-col items-start text-black dark:text-white">
                        <div class="flex flex-col">
                            <a class="block w-fit mb-2" href="">All Products</a>
                            <a class="block w-fit mb-2" href="">Create new product</a>
                        </div>
                    </div>
                    <main
                        class="w-3/4 bg-white dark:bg-gray-800 p-8 rounded-xl shadow-xl ml-4 transition-all duration-300">
                        <h2 class="text-xl font-bold mb-4 text-black dark:text-white">Create New Product</h2>
                        <form autocomplete="off" action="/products/create" method="POST" enctype="multipart/form-data">
                            <div class="mb-6">
                                <h3 class="text-lg font-semibold mb-2 text-black dark:text-white">Product Details</h3>
                                <div class="mb-4">
                                    <label class="block mb-2 font-medium text-black dark:text-white">Product
                                        Image</label>
                                    <input name="image" type="file"
                                        class="py-2 px-4 rounded text-black dark:text-white file:bg-blue-600 file:text-white file:border-0 file:px-4 file:py-2 file:rounded file:cursor-pointer">
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <input name="name" type="text" placeholder="Product Name"
                                        class="border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-black dark:text-white placeholder-gray-500 dark:placeholder-gray-400 p-2 rounded w-full transition-all duration-300">
                                    <input name="price" type="text" placeholder="Product Price"
                                        class="border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-black dark:text-white placeholder-gray-500 dark:placeholder-gray-400 p-2 rounded w-full transition-all duration-300">
                                    <input name="discount" type="text" placeholder="Discount Price"
                                        class="border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-black dark:text-white placeholder-gray-500 dark:placeholder-gray-400 p-2 rounded w-full transition-all duration-300">
                                </div>
                            </div>

                            <div>
                                <h3 class="text-lg font-semibold mb-2 text-black dark:text-white">Panel Details</h3>
                                <div class="grid grid-cols-2 gap-4">
                                    <!-- Background Color  -->
                                    <div class="flex flex-col gap-2">
                                        <label class="font-medium text-black dark:text-white">Background Color</label>

                                        <input name="bgcolor" type="color" value="#DBEAFE"
                                            class="w-full h-12 rounded-lg cursor-pointer border border-gray-300 dark:border-gray-600">
                                    </div>
                                    <!-- panelcolor           -->
                                    <div class="flex flex-col gap-2">
                                        <label class="font-medium text-black dark:text-white">Panel Color</label>

                                        <input name="panelcolor" type="color" value="#2563EB"
                                            class="w-full h-12 rounded-lg cursor-pointer border border-gray-300 dark:border-gray-600">
                                    </div>
                                    <!-- TextColor                                      -->
                                    <div class="flex flex-col gap-2">
                                        <label class="font-medium text-black dark:text-white">Text Color</label>

                                        <input name="textcolor" type="color" value="#FFFFFF"
                                            class="w-full h-12 rounded-lg cursor-pointer border border-gray-300 dark:border-gray-600">
                                    </div>
                                </div>
                            </div>
                            <input
                                class="px-5 py-2 rounded mt-4 bg-blue-600 hover:bg-blue-700 transition-all duration-300 text-white"
                                type="submit" value="Create New Product">
                        </form>
                        <hr class="my-10 border-gray-300 dark:border-gray-600">

<h2 class="text-2xl font-bold mb-5 text-black dark:text-white">
    Pending Seller Requests
</h2>

<% if(pendingUsers.length === 0){ %>

    <p class="text-gray-500 dark:text-gray-400">
        No pending seller requests.
    </p>

<% } else { %>

    <div class="space-y-4">

        <% pendingUsers.forEach(function(user){ %>

            <div class="flex justify-between items-center p-4 rounded-lg border dark:border-gray-700">

                <div>
                    <h3 class="text-lg font-semibold text-black dark:text-white">
                        <%= user.fullname %>
                    </h3>

                    <p class="text-gray-500 dark:text-gray-400">
                        <%= user.email %>
                    </p>
                </div>

                <div class="flex gap-3">

                    <a href="/owners/approve/<%= user._id %>"
                        class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg">

                        Approve

                    </a>

                    <a href="/owners/reject/<%= user._id %>"
                        class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg">

                        Reject

                    </a>

                </div>

            </div>

        <% }) %>

    </div>

<% } %>
                    </main>
                </div>
            </div>
            <%- include('./partials/footer') %>