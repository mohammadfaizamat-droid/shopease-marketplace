<%- include('./partials/header') %>

<div class="w-full h-screen flex justify-center items-center">

    <div class="w-[420px] bg-white dark:bg-gray-800 shadow-xl rounded-xl p-8">

        <h2 class="text-3xl font-bold text-center mb-6">
            Owner Login
        </h2>

        <form action="/owners/login" method="POST">

            <input
                type="email"
                name="email"
                placeholder="Email"
                class="w-full border rounded-lg p-3 mb-4 bg-white dark:bg-gray-700 dark:text-white">

            <input
                type="password"
                name="password"
                placeholder="Password"
                class="w-full border rounded-lg p-3 mb-6 bg-white dark:bg-gray-700 dark:text-white">

            <button
                class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg">

                Login

            </button>

        </form>

    </div>

</div>

<%- include('./partials/footer') %>